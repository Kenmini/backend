# --- Secrets & credentials -------------------------------------------------
# Never commit real credentials. boto3 reads them from `aws configure` or .env.
.env
.env.*
!.env.example
*.pem
# AWS console credential dumps are exported as .csv / .txt — keep them out.
*.csv
*.txt
# ...but the dependency list must stay tracked.
!requirements.txt

# --- Runtime data ----------------------------------------------------------
# Local knowledge-gap store, written at runtime.
gaps.json

# --- Python ----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# --- Virtual environments --------------------------------------------------
.venv/
venv/
env/
ENV/

# --- Tooling / caches ------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- OS / editor -----------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

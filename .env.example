# .env.example — copy to .env and fill in ONLY if you are NOT using `aws configure`.
#
#   cp .env.example .env      (macOS/Linux)
#   copy .env.example .env    (Windows)
#
# PLACEHOLDER VALUES ONLY in this file. Never put real keys here.
# The real .env is gitignored and must never be committed.
#
# Preferred path: run `aws configure` and leave the credential lines below
# blank/commented — boto3 will pick up your AWS profile automatically.

# --- AWS credentials (only if NOT using `aws configure`) -------------------
AWS_ACCESS_KEY_ID=your-access-key-id-here
AWS_SECRET_ACCESS_KEY=your-secret-access-key-here
# AWS_SESSION_TOKEN=only-needed-for-temporary-credentials

# --- Region & resources (non-secret identifiers; override if you fork) ------
AWS_REGION=us-east-1
KB_ID=AJVVEPYMSH
AWS_ACCOUNT_ID=465239007752

# --- Models ----------------------------------------------------------------
MODEL_SMART=us.anthropic.claude-sonnet-4-6
MODEL_FAST=us.anthropic.claude-haiku-4-5-20251001-v1:0
# If retrieve_and_generate rejects the foundation-model ARN with an on-demand
# throughput error, uncomment this inference-profile ARN override:
# MODEL_SMART_ARN=arn:aws:bedrock:us-east-1:465239007752:inference-profile/us.anthropic.claude-sonnet-4-6

# --- Behaviour -------------------------------------------------------------
GAP_THRESHOLD=0.4
ANSWER_PATH=easy
# NUM_RESULTS=5
